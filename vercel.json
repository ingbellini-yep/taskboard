{
  "version": 2,
  "rewrites": [
    { "source": "/api/cron", "destination": "/api/index.py" },
    { "source": "/api/webhook", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "20 5 * * *"
    }
  ]
}