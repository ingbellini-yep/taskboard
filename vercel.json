{
  "version": 2,
  "functions": {
    "api/webhook.py": { "runtime": "python3.12", "maxDuration": 10 },
    "api/cron.py":    { "runtime": "python3.12", "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/webhook", "dest": "/api/webhook.py" },
    { "src": "/api/cron",    "dest": "/api/cron.py"    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "20 5 * * *"
    }
  ]
}
