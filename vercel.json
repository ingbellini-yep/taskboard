{
  "version": 2,
  "functions": {
    "api/webhook.py": { "runtime": "@vercel/python", "maxDuration": 10 },
    "api/cron.py":    { "runtime": "@vercel/python", "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "20 5 * * *"
    }
  ]
}